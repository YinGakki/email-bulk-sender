# 安全密钥（用于session加密，随机生成）
SECRET_KEY=your-secret-key-change-this

# 页面访问密码（留空则不启用密码保护）
ACCESS_PASSWORD=your-access-password

# 以下邮箱配置已移至「设置」页面管理，无需在此处配置
# 如需通过环境变量预设默认值，可取消下方注释
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=587
# SMTP_USERNAME=your_qq@qq.com
# SMTP_PASSWORD=your_authorization_code
# SENDER_NAME=发件人名称
# BATCH_SIZE=10
# SEND_INTERVAL=5
